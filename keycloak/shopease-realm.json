    },
    {
      "username": "raslen",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Raslen",
      "lastName": "Ferchichi",
      "email": "raslen@shopease.com",
      "credentials": [
        {
          "type": "password",
          "value": "raslenferchichi",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ROLE_USER",
        "default-roles-shopease"
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "ShopEase",
      "email": "admin@shopease.com",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
